# ClickHouse connection (copy to .env and fill CH_PASSWORD)
# Leave CH_HOST blank to auto-pick: 127.0.0.1 -> 192.168.122.226 -> 100.115.36.121
CH_HOST=
CH_HTTP_PORT=8124
CH_NATIVE_PORT=9000
CH_USER=admin_nmt
CH_PASSWORD=
CH_DATABASE=crypto

# What to crawl
EXCHANGE=binance
MARKET_TYPE=um              # um (USDM futures) | spot  — selects endpoints AND the pairs.yaml section
# Which pairs each market collects is declared in pairs.yaml (markets.<um|spot>),
# NOT here. Override the demo universe file path for container mounts via DEMO_SYMBOLS_JSON.
DATASETS=trades,bookDepth,metrics
# KLINE_INTERVALS=          # blank => all Binance intervals (spot also gets 1s)

# Backfill range (UTC, YYYY-MM-DD). Blank START => last 30 days. Blank END => today-1.
START_DATE=
END_DATE=

# Tuning (defaults sized for an 8-CPU box shared with ClickHouse)
WORKERS=4                   # backfill process pool size (leave CPU/headroom for CH)
INSERT_BATCH=100000         # rows per ClickHouse insert
L2_LEVELS=20                # live order book depth levels (5|10|20)
LIVE_GROUPS=3               # order-book WS processes
KLINE_GROUPS=2              # kline WS processes (ohlcv, all intervals, closed candles)
OI_FUNDING_SECS=5.0         # real-time open-interest + funding-rate poll period (futures)
LIVE_FLUSH_ROWS=50000       # buffer high-water (memory cap); flush early if buf hits this
LIVE_FLUSH_SECS=2.0         # normal flush cadence (time-based; keeps CH part-count low)
